{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM Proxy",
      "options": {
        "baseURL": "http://localhost:15000/v1",
        "apiKey": "sk-1234"
      },
      "models": {
        "gpt-5.2": {
          "name": "gpt-5.2",
          "type": "chat",
          "limit": {
            "context": 100000,
            "input": 100000,
            "output": 16000
          }
        }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 2000
  },
  "agent": {
    "default": {
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  }
}
